{
  "name": "@veams/form",
  "version": "0.2.0",
  "description": "Form state handlers and React bindings for the VEAMS StatusQuo ecosystem.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": "./dist/index.js"
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": "./dist/react/index.js"
    },
    "./validators": {
      "import": {
        "types": "./dist/validators/index.d.ts",
        "default": "./dist/validators/index.js"
      },
      "require": "./dist/validators/index.js"
    },
    "./validators/zod": {
      "import": {
        "types": "./dist/validators/zod.d.ts",
        "default": "./dist/validators/zod.js"
      },
      "require": "./dist/validators/zod.js"
    }
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "npm-run-all compile",
    "bundle:ts": "tsc --project tsconfig.json",
    "check:types": "tsc --skipLibCheck --noEmit",
    "compile": "npm-run-all bundle:ts",
    "lint": "npm run lint:ts",
    "lint:ts": "eslint --fix \"src/**/*.{tsx,ts}\"",
    "test": "cross-env NODE_ENV=test jest --config jest.config.cjs",
    "test:types": "tsc --noEmit --project tsconfig.type-tests.json",
    "release": "npm run build && release-it"
  },
  "peerDependencies": {
    "@veams/status-quo": ">=1.5.1",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "1.15.11",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.0.0",
    "@veams/status-quo": "^1.5.1",
    "cross-env": "10.1.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "npm-run-all": "4.1.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "release-it": "19.2.4",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  },
  "keywords": [
    "Forms",
    "StatusQuo",
    "React"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Sebastian Fitzner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veams/veams.git",
    "directory": "packages/form"
  },
  "bugs": {
    "url": "https://github.com/Veams/veams/issues"
  }
}
