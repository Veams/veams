{
  "name": "@veams/status-quo-query",
  "version": "0.11.0",
  "description": "TanStack Query service layer for the VEAMS StatusQuo ecosystem.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": "./dist/index.js"
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": "./dist/react/index.js"
    },
    "./mutation": {
      "import": {
        "types": "./dist/mutation.d.ts",
        "default": "./dist/mutation.js"
      },
      "require": "./dist/mutation.js"
    },
    "./query": {
      "import": {
        "types": "./dist/query.d.ts",
        "default": "./dist/query.js"
      },
      "require": "./dist/query.js"
    },
    "./provider": {
      "import": {
        "types": "./dist/provider.d.ts",
        "default": "./dist/provider.js"
      },
      "require": "./dist/provider.js"
    }
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "npm-run-all compile",
    "bundle:ts": "tsc --project tsconfig.json",
    "check:types": "tsc --skipLibCheck --noEmit",
    "compile": "npm-run-all bundle:ts",
    "lint": "npm run lint:ts",
    "lint:ts": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "test": "cross-env NODE_ENV=test jest --config jest.config.cjs",
    "release": "npm run build && release-it"
  },
  "peerDependencies": {
    "@tanstack/query-core": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "1.15.11",
    "@swc/jest": "0.2.39",
    "@tanstack/query-core": "5.91.2",
    "@types/jest": "30.0.0",
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.0.0",
    "cross-env": "10.1.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "npm-run-all": "4.1.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "release-it": "19.2.4",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  },
  "keywords": [
    "TanStack Query",
    "StatusQuo",
    "Service Layer"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Sebastian Fitzner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veams/veams.git",
    "directory": "packages/status-quo-query"
  },
  "bugs": {
    "url": "https://github.com/Veams/veams/issues"
  },
  "release-it": {
    "git": {
      "tagName": "${npm.name}@${version}",
      "pushRepo": "origin",
      "commitMessage": "chore(status-quo-query): release ${npm.name}@${version}"
    },
    "github": {
      "release": true,
      "releaseName": "${npm.name}@${version}"
    },
    "npm": {
      "publish": true
    }
  }
}
